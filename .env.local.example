# Copy this file to .env.local and fill in your values
# Get these from your Supabase project: Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — used server-side only for admin operations (bypasses RLS)
# Get from: Supabase > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Comma-separated list of admin email addresses (can access /dashboard/admin)
ADMIN_EMAILS=you@example.com

# Never commit .env.local — it's in .gitignore

# ── Stripe (payments) ────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get from: stripe listen --forward-to localhost:3000/api/stripe/webhook
# or Dashboard > Developers > Webhooks (events: checkout.session.completed, customer.subscription.deleted)
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring Price IDs — create Products in Stripe Dashboard, copy price IDs
STRIPE_PRICE_PREMIUM=price_...   # Individual Premium $4.99/mo
STRIPE_PRICE_BASIC=price_...     # Agency Basic $99/mo
STRIPE_PRICE_PRO=price_...       # Agency Pro $249/mo
